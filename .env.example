# ═══════════════════════════════════════════════════════════════
# BlockForge AI — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file.
# ═══════════════════════════════════════════════════════════════

# ── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── GPU / Processing ────────────────────────────────────────────
GPU_DEVICE=cuda:0           # Use "mps" for Apple Silicon, "cpu" as fallback
USE_FP16=true               # Mixed precision — disable on CPU
GPU_BATCH_SIZE=4            # Frames processed per GPU batch

# ── Video Encoding ──────────────────────────────────────────────
DEFAULT_CRF=18              # CRF quality (0 = lossless, 51 = worst)
DEFAULT_CODEC=libx264       # Encoder: libx264 | libx265 | libvpx-vp9
MAX_VIDEO_SIZE_MB=500       # Maximum upload size in MB

# ── API ─────────────────────────────────────────────────────────
DEBUG=false                 # Set true for hot-reload in development
API_HOST=0.0.0.0
API_PORT=8000

# ── Frontend ────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
