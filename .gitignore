# ═══════════════════════════════════════════════════════════════
# BlockForge AI — .gitignore
# ═══════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────
# 🤖 AI Model Weights (large binary files)
# ──────────────────────────────────────────────
ai_models/
*.pth
*.pt
*.ckpt
*.safetensors
*.bin
*.onnx
*.tflite

# ──────────────────────────────────────────────
# 🐍 Python
# ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
.cache/
pip-log.txt
pip-delete-this-directory.txt
.tox/
.nox/
.coverage
.coverage.*
.hypothesis/
.pytest_cache/
cover/
htmlcov/
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
cython_debug/

# Virtual environments
venv/
.venv/
ENV/
env/
env.bak/
venv.bak/
.virtualenv/

# ──────────────────────────────────────────────
# 📦 Node.js / Next.js
# ──────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# Next.js build output
.next/
out/
build/
dist/

# Vercel
.vercel

# npm / yarn / pnpm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json.bak

# ──────────────────────────────────────────────
# 🔐 Environment & Secrets
# ──────────────────────────────────────────────
.env
.env.*
!.env.example
!.env.local.example
*.pem
*.key
secrets/
credentials/

# ──────────────────────────────────────────────
# 🐳 Docker
# ──────────────────────────────────────────────
.docker/
docker-data/

# ──────────────────────────────────────────────
# 📂 Data / Media / Uploads (runtime artifacts)
# ──────────────────────────────────────────────
data/
uploads/
frames/
output/
masks/
temp/
tmp/
*.mp4
*.avi
*.mov
*.mkv
*.webm
# Allow sample assets in specific folders
!public/**/*.mp4
!docs/**/*.gif

# ──────────────────────────────────────────────
# 🍎 macOS
# ──────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.AppleDouble
.LSOverride
Icon
.DocumentRevisions-V100
.fseventsd
.TemporaryItems

# ──────────────────────────────────────────────
# 🪟 Windows
# ──────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ──────────────────────────────────────────────
# 🐧 Linux
# ──────────────────────────────────────────────
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ──────────────────────────────────────────────
# 🛠 IDEs & Editors
# ──────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-workspace
*.sublime-project
.history/
.ionide/

# ──────────────────────────────────────────────
# 📋 Logs
# ──────────────────────────────────────────────
logs/
*.log
celery*.log
uvicorn*.log
npm-debug.log*

# ──────────────────────────────────────────────
# 🧪 Testing
# ──────────────────────────────────────────────
.pytest_cache/
coverage/
.nyc_output/

# ──────────────────────────────────────────────
# 📊 Jupyter
# ──────────────────────────────────────────────
.ipynb_checkpoints
*.ipynb

# ──────────────────────────────────────────────
# 🗜 Archives
# ──────────────────────────────────────────────
*.zip
*.tar.gz
*.tar.bz2
*.rar
*.7z
